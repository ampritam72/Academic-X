rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'abirmahmudpritam001@gmail.com' ||
        request.auth.token.email == 'abirmahmudpritam@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string
        && id.size() <= 128
        && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUserCreate(data) {
      return (data.get('fullName', '') is string || data.get('fullName', '') == null)
        && (data.get('email', '') is string || data.get('email', '') == null)
        && data.get('studentId', '') is string
        && data.get('studentId', '').size() <= 20;
    }

    function isValidUserUpdate(data) {
      return (data.get('fullName', '') is string || data.get('fullName', '') == null)
        && (data.get('email', '') is string || data.get('email', '') == null)
        && data.get('studentId', '') is string
        && data.get('studentId', '').size() <= 20;
    }

    function isValidNote(data) {
      return data.userId == request.auth.uid
        && data.title is string
        && data.title.size() <= 200
        && data.content is string
        && data.content.size() <= 50000;
    }

    // ---------- Users ----------
    match /users/{userId} {
      allow read, get, list: if true; // Allow public access to support student ID lookup during login/registration

      allow create: if (isOwner(userId) || isAdmin())
        && isValidId(userId)
        && incoming().keys().hasAll(['fullName', 'email', 'studentId'])
        && isValidUserCreate(incoming())
        && incoming().email == request.auth.token.email;

      allow update: if (isOwner(userId) || isAdmin())
        && isValidUserUpdate(incoming())
        && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly([
          'fullName', 'avatarUrl', 'photoUrl', 'batch', 'section', 
          'department', 'semester', 'points', 'streakDays', 'cgpa', 
          'savedNotesCount', 'updatedAt', 'lastLoginAt', 'myClubs'
        ]));

      allow delete: if isAdmin();
    }

    // ---------- Notices ----------
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ---------- Slides ----------
    match /slides/{slideId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ---------- Study Notes ----------
    match /users/{userId}/studyNotes/{noteId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && isValidId(noteId)
        && isValidNote(incoming());

      allow update: if isOwner(userId)
        && isValidNote(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly([
          'title',
          'content',
          'updatedAt'
        ]);

      allow delete: if isOwner(userId);
    }

    // ---------- Clubs ----------
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isSignedIn() && resource.data.leaderUid == request.auth.uid
      );
    }

    // ---------- Club Events ----------
    match /clubs/{clubId}/events/{eventId} {
      allow read: if isSignedIn();

      allow create, delete: if isAdmin() ||
        (
          isSignedIn()
          && get(/databases/$(database)/documents/clubs/$(clubId)).data.leader.leaderUid == request.auth.uid
        );

      allow update: if isAdmin() ||
        (
          isSignedIn() && (
            (get(/databases/$(database)/documents/clubs/$(clubId)).data.leader.leaderUid == request.auth.uid) ||
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interestedUids'])
          )
        );
    }

    // ---------- Section Configs ----------
    match /sectionConfigs/{configId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ---------- Chats ----------
    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      
      match /messages/{messageId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && isValidId(messageId)
          && incoming().senderId == request.auth.uid;

        allow update, delete: if false;
      }
    }

    // ---------- Section Notices ----------
    match /section_notices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn(); // Allowing all signed in users just for demo/prototype, though ideally it should check CR role
    }

    // ---------- Department Notices ----------
    match /dept_notices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ---------- Assignments ----------
    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ---------- User Roles (Database 2) ----------
    match /userRoles/{studentId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------- Global Safety Net ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}