rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'abirmahmudpritam001@gmail.com' ||
        request.auth.token.email == 'abirmahmudpritam@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.studentId is string && data.studentId.size() <= 20
        && data.fullName is string && data.fullName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (data.get('roles', []) is list)
        && (data.get('points', 0) is int)
        && (data.get('streakDays', 0) is int);
    }

    function isValidNote(data) {
      return data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.content is string && data.content.size() <= 50000;
    }

    // --- Rules ---

    // 1. Users
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin(); // Only admins can list users
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().keys().hasAll(['studentId', 'fullName', 'email'])
        && !('Admin' in incoming().get('roles', [])); // Can't self-promote to Admin
        
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && (
          // Action: Profile Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'avatarUrl', 'batch', 'section', 'department'])) ||
          // Action: Simple Points/Streak (Should be server side but for MVP allow small increments)
          (incoming().diff(existing()).affectedKeys().hasOnly(['points', 'streakDays', 'cgpa']))
        )
        && incoming().email == existing().email; // Email is immutable
    }

    // 2. Notices
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(); // For now only admins can post notices
    }

    // 3. Slides
    match /slides/{slideId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 4. Study Notes
    match /users/{userId}/studyNotes/{noteId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidNote(incoming());
      allow update: if isOwner(userId) && isValidNote(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content']);
      allow delete: if isOwner(userId);
    }

    // 5. Clubs
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. Club Events
    match /clubs/{clubId}/events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/clubs/$(clubId)).data.presidentId == request.auth.uid);
    }

    // 7. Chats
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if isSignedIn(); // Basic chat security for MVP
    }
  }
}
